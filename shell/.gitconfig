[color]
    ui = auto
[core]
    editor = nvim
	excludesfile = ~/.gitignore_global
[alias]
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
    tracking = rev-parse --symbolic-full-name --abbrev-ref @{u}
	lg = "!f() { upstream=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null); ahead=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo 0); if [ -n \"$upstream\" ] && [ \"$ahead\" -gt 0 ]; then git lglong --max-count $((ahead + 1)); else git lglong --max-count 10; fi; }; f"
	lglong = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ci)%C(bold blue)<%an>%Creset' --abbrev-commit
	lgdiverge = !git lglong HEAD @{u} --not $(git merge-base HEAD @{u})^
	lgdivergelr = !git lglong --left-right --boundary HEAD...@{u}
	lgremote = !git lglong HEAD origin/$(git branchname) --not $(git merge-base HEAD origin/$(git branchname))^
	lgme = !git lglong --author=\"$(git config user.email)\"
	lgall = !git lglong --all --date-order
    diffremote = !git diff origin/$(git branchname)..HEAD
    rbt = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s' --abbrev-commit
    graph = log --graph --date-order -C -M --pretty=format:\"<%h> %ad [%an] %Cgreen%d%Creset %s\" --all --date=short
    branchname = symbolic-ref --short HEAD
    msg = log -1 --pretty=%s
    br = !git for-each-ref --sort=committerdate refs/heads/ --format='%(HEAD) %(align:30,left)%(color:normal)%(refname:short)%(color:reset)%(end) %(color:normal dim)%(objectname:short)%(color:reset) %(color:green)(%(committerdate:relative))%(color:reset)'
	cleanup = !git branch --merged | grep -vE \"^[* ]+(main|master|develop)$\" | xargs -r git branch -d
    aliases = config --get-regexp alias
    last = log -1 HEAD --stat
	new = "!f() { base=\"${2:-origin/main}\"; [ \"$base\" = \".\" ] && base=\"$(git symbolic-ref --short HEAD)\"; git checkout --track -b \"$1\" \"$base\"; }; f"
	pfwl = !git push origin HEAD:$(git branchname) --force-with-lease --force-if-includes
	setup-bare = !git config remote.origin.fetch \"+refs/heads/*:refs/remotes/origin/*\" && git fetch origin
	#clone-bare = "!f() { local dir=\"${2:-$(basename \"$1\" .git).git}\"; git clone --bare \"$1\" \"$dir\" && git -C \"$dir\" setup-bare; }; f"
	rom = !git fetch --all && git rebase origin/main
[log]
    decorate = true
[pull]
	rebase = true
[rerere]
	enabled = true

# Include local settings (name, email, work-specific config)
# Create ~/.gitconfig.local with your personal information
[include]
    path = ~/.gitconfig.local
[coderabbit]
	machineId = cli/93a2e6506b9f4d06af08de7dc92b758c
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[diff]
	algorithm = histogram

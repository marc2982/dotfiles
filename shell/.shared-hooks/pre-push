#!/bin/bash

# pre-push hook that fetches and attempts to rebase before pushing
# If conflicts occur, the push is rejected

set -e

# current_branch=$(git symbolic-ref --short HEAD)  # Unused, commented out
remote="$1"
url="$2"

# Run generate, lint, and tidy checks before pushing
tmplog=$(mktemp)
trap 'rm -f "$tmplog"' EXIT

make_targets=""
for target in generate lint; do
    if make -n "$target" > /dev/null 2>&1; then
        make_targets="$make_targets $target"
    fi
done
if [ -n "$make_targets" ]; then
    echo "Pre-push: Running 'make$make_targets'..."
    if ! make $make_targets > "$tmplog" 2>&1; then
        echo "✗ 'make$make_targets' failed, rejecting push"
        cat "$tmplog"
        exit 1
    fi
fi

if command -v go > /dev/null 2>&1 && [ -f go.mod ]; then
    echo "Pre-push: Running 'go mod tidy'..."
    if ! go mod tidy > "$tmplog" 2>&1; then
        echo "✗ 'go mod tidy' failed, rejecting push"
        cat "$tmplog"
        exit 1
    fi
fi

# Check for any dirty changes (unstaged, staged, or untracked generated files)
if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "✗ Dirty changes detected after running 'make generate lint' and 'go mod tidy'"
    echo "  Please review and commit the changes before pushing:"
    git diff --stat
    git diff --cached --stat
    exit 1
fi

# Read the refs being pushed from stdin
while read local_ref local_sha remote_ref remote_sha; do
    # Only process branch pushes (not tags)
    if [[ "$local_ref" =~ ^refs/heads/ ]]; then
        branch_name="${local_ref#refs/heads/}"

        echo "Pre-push: Fetching latest changes for $branch_name..."

        # Fetch the remote branch
        if ! git fetch "$remote" "$branch_name" 2>/dev/null; then
            echo "Note: Remote branch doesn't exist yet, proceeding with push"
            continue
        fi

        # Check if remote branch has commits we don't have
        remote_branch="$remote/$branch_name"
        merge_base=$(git merge-base HEAD "$remote_branch" 2>/dev/null || echo "")
        remote_head=$(git rev-parse "$remote_branch" 2>/dev/null || echo "")

        if [ -z "$merge_base" ] || [ -z "$remote_head" ]; then
            echo "Note: Could not determine merge base, proceeding with push"
            continue
        fi

        # If remote has new commits, try to rebase
        if [ "$merge_base" != "$remote_head" ]; then
            echo "Pre-push: Remote has new commits, attempting rebase..."

            # Attempt the rebase
            if git rebase "$remote_branch"; then
                echo "✓ Rebase successful!"

                # Verify we're still up-to-date after rebase (catch race conditions)
                git fetch "$remote" "$branch_name" 2>/dev/null || true
                remote_head_after=$(git rev-parse "$remote_branch" 2>/dev/null || echo "")

                if [ -n "$remote_head_after" ] && ! git merge-base --is-ancestor "$remote_branch" HEAD; then
                    echo "✗ Remote changed during rebase, please push again"
                    exit 1
                fi

                echo "Pre-push: Please run your push command again to push the rebased commits"
                exit 1
            else
                # Rebase failed (conflicts)
                echo "✗ Rebase failed due to conflicts"
                echo "Pre-push: Aborting rebase and rejecting push"
                git rebase --abort
                exit 1
            fi
        fi
    fi
done

# If we get here, no rebase was needed or refs were not branches
echo "Branch up-to-date, pushing"
exit 0
